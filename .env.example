# .env.example — variable names only, no real values.
# Copy to .env (gitignored) and fill in values for local development.
# In production, Apify sets APIFY_* vars automatically.

# Apify platform (injected at runtime — only needed for local runs)
APIFY_TOKEN=your_apify_token_here
APIFY_CONTAINER_PORT=3000

# Session tuning (optional overrides)
SESSION_TIMEOUT_SECS=300
